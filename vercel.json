{
  "version": 2,
  "builds": [
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "*.txt", "use": "@vercel/static" },
    { "src": "*.xml", "use": "@vercel/static" },
    { "src": "*.png", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/privacy", "dest": "/privacy.html" },
    { "src": "/terms", "dest": "/terms.html" },
    { "src": "/_next/(.*)", "dest": "https://foodtruckpos-dashboard.vercel.app/_next/$1" },
    { "src": "/login", "dest": "https://foodtruckpos-dashboard.vercel.app/login" },
    { "src": "/login/(.*)", "dest": "https://foodtruckpos-dashboard.vercel.app/login/$1" },
    { "src": "/dashboard", "dest": "https://foodtruckpos-dashboard.vercel.app/dashboard" },
    { "src": "/dashboard/(.*)", "dest": "https://foodtruckpos-dashboard.vercel.app/dashboard/$1" },
    { "src": "/", "dest": "/index.html" }
  ]
}
